# Google Cloud
GOOGLE_CLOUD_PROJECT=agentrial-prod
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-004

# Chroma (local)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=mekano_parts

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production

# MLflow
MLFLOW_TRACKING_URI=./mlflow_runs
MLFLOW_EXPERIMENT_NAME=mekano-embeddings

# Precios
# Tipo de cambio BRL → USD
# Actualizar cuando cambie significativamente
# Referencia: https://www.google.com/finance/quote/USD-BRL
BRL_TO_USD_RATE=5.75
PRICE_LIST_FILE=data/raw/listado_precios_CC_2026.xlsx